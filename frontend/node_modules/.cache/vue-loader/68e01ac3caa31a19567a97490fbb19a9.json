{"remainingRequest":"/home/rob/HLaS/frontend/node_modules/vue-loader/lib/index.js??vue-loader-options!/home/rob/HLaS/frontend/App.vue?vue&type=style&index=0&id=472cff63&lang=css","dependencies":[{"path":"/home/rob/HLaS/frontend/App.vue","mtime":1772488352887},{"path":"/home/rob/HLaS/frontend/node_modules/css-loader/dist/cjs.js","mtime":1772483434588},{"path":"/home/rob/HLaS/frontend/node_modules/vue-loader/lib/loaders/stylePostLoader.js","mtime":1772483434726},{"path":"/home/rob/HLaS/frontend/node_modules/postcss-loader/src/index.js","mtime":1772483434563},{"path":"/home/rob/HLaS/frontend/node_modules/cache-loader/dist/cjs.js","mtime":1772483434576},{"path":"/home/rob/HLaS/frontend/node_modules/vue-loader/lib/index.js","mtime":1772483434562}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:CiNhcHAgewogIG1heC13aWR0aDogNjAwcHg7CiAgbWFyZ2luOiBhdXRvOwogIGZvbnQtZmFtaWx5OiBBcmlhbCwgc2Fucy1zZXJpZjsKfQpmb3JtIHsKICBtYXJnaW4tYm90dG9tOiAyMHB4Owp9CmlucHV0IHsKICBtYXJnaW4tcmlnaHQ6IDEwcHg7Cn0KYnV0dG9uIHsKICBtYXJnaW4tcmlnaHQ6IDVweDsKfQo="},{"version":3,"sources":["App.vue"],"names":[],"mappings":";AAsHA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"App.vue","sourceRoot":".","sourcesContent":["<template>\n  <div id=\"app\">\n    <h1>Fishing Club Members</h1>\n    <form @submit.prevent=\"addMember\">\n      <input v-model=\"newMember.name\" placeholder=\"Name\" required />\n      <input v-model=\"newMember.email\" placeholder=\"Email\" />\n      <input v-model=\"newMember.phone\" placeholder=\"Phone\" />\n      <input v-model=\"newMember.membership_type\" placeholder=\"Membership Type\" />\n      <button type=\"submit\">Add Member</button>\n    </form>\n    <ul>\n      <li v-for=\"member in members\" :key=\"member.id\">\n        {{ member.name }} - {{ member.email }} - {{ member.phone }} - {{ member.membership_type }}\n        <button @click=\"editMember(member)\">Edit</button>\n        <button @click=\"deleteMember(member.id)\">Delete</button>\n      </li>\n    </ul>\n    <div v-if=\"editing\">\n      <h2>Edit Member</h2>\n      <form @submit.prevent=\"updateMember\">\n        <input v-model=\"editMemberData.name\" placeholder=\"Name\" required />\n        <input v-model=\"editMemberData.email\" placeholder=\"Email\" />\n        <input v-model=\"editMemberData.phone\" placeholder=\"Phone\" />\n        <input v-model=\"editMemberData.membership_type\" placeholder=\"Membership Type\" />\n        <button type=\"submit\">Save</button>\n        <button @click=\"cancelEdit\">Cancel</button>\n      </form>\n    </div>\n    <hr />\n    <div>\n      <h2>Lookup Member by Number</h2>\n      <form @submit.prevent=\"lookupMember\">\n        <input v-model=\"lookupNumber\" placeholder=\"Membership Number\" required />\n        <button type=\"submit\">Lookup</button>\n      </form>\n      <div v-if=\"lookupError\" style=\"color: red;\">{{ lookupError }}</div>\n      <table v-if=\"lookupResult\">\n        <tr>\n          <th v-for=\"(value, key) in lookupResult\" :key=\"key\">{{ key }}</th>\n        </tr>\n        <tr>\n          <td v-for=\"(value, key) in lookupResult\" :key=\"key\">{{ value }}</td>\n        </tr>\n      </table>\n    </div>\n  </div>\n</template>\n\n<script>\nimport axios from 'axios';\n\nexport default {\n  data() {\n    return {\n      members: [],\n      newMember: { name: '', email: '', phone: '', membership_type: '' },\n      editing: false,\n      editMemberData: {},\n      editMemberId: null,\n      lookupNumber: '',\n      lookupResult: null,\n      lookupError: ''\n    };\n  },\n  created() {\n    this.fetchMembers();\n  },\n  methods: {\n    fetchMembers() {\n      axios.get('http://localhost:5000/members').then(res => {\n        this.members = res.data;\n      });\n    },\n    addMember() {\n      axios.post('http://localhost:5000/members', this.newMember).then(() => {\n        this.fetchMembers();\n        this.newMember = { name: '', email: '', phone: '', membership_type: '' };\n      });\n    },\n    editMember(member) {\n      this.editing = true;\n      this.editMemberData = { ...member };\n      this.editMemberId = member.id;\n    },\n    updateMember() {\n      axios.put(`http://localhost:5000/members/${this.editMemberId}`, this.editMemberData).then(() => {\n        this.fetchMembers();\n        this.editing = false;\n        this.editMemberData = {};\n        this.editMemberId = null;\n      });\n    },\n    cancelEdit() {\n      this.editing = false;\n      this.editMemberData = {};\n      this.editMemberId = null;\n    },\n    deleteMember(id) {\n      axios.delete(`http://localhost:5000/members/${id}`).then(() => {\n        this.fetchMembers();\n      });\n    },\n    lookupMember() {\n      this.lookupResult = null;\n      this.lookupError = '';\n      axios.get(`http://localhost:5000/member_by_number/${encodeURIComponent(this.lookupNumber)}`)\n        .then(res => {\n          this.lookupResult = res.data;\n        })\n        .catch(err => {\n          this.lookupError = err.response && err.response.data && err.response.data.error ? err.response.data.error : 'Error retrieving member';\n        });\n    }\n  }\n};\n</script>\n\n<style>\n#app {\n  max-width: 600px;\n  margin: auto;\n  font-family: Arial, sans-serif;\n}\nform {\n  margin-bottom: 20px;\n}\ninput {\n  margin-right: 10px;\n}\nbutton {\n  margin-right: 5px;\n}\n</style>\n"]}]}